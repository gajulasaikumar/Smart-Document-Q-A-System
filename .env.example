APP_NAME=Smart Document Q&A API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
LLM_PROVIDER=openai
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=openai/gpt-oss-120b:groq
LLM_TIMEOUT_SECONDS=45
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DATABASE_URL=postgresql+psycopg://smartdoc:smartdoc@db:5432/smart_document
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DATA_DIR=/app/data
MAX_UPLOAD_BYTES=15728640
CHUNK_TARGET_CHARS=900
CHUNK_OVERLAP_CHARS=180
RETRIEVAL_TOP_K=5
RETRIEVAL_PER_DOCUMENT_K=3
RETRIEVAL_MIN_SCORE=0.28
QA_MAX_CONTEXT_CHARS=6000
QUESTION_HISTORY_MESSAGES=6
POSTGRES_DB=smart_document
POSTGRES_USER=smartdoc
POSTGRES_PASSWORD=smartdoc
